PORT=5000
MONGO_URI=mongodb://localhost:27017/gramseva
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRE=7d
NODE_ENV=development

# ── OTP SMS (choose one) ──
# Fast2SMS (India) — Free: https://fast2sms.com → Dashboard → Dev API
FAST2SMS_API_KEY=your_fast2sms_api_key

# Twilio (Global) — https://console.twilio.com
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE=+1415XXXXXXX

# ── Payment (Razorpay) ──
# https://dashboard.razorpay.com → Settings → API Keys
# RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX
# RAZORPAY_KEY_SECRET=your_razorpay_secret
-e 
# ANTHROPIC AI (for GramMitra Chatbot)
# Get free key: https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxx
-e 
# AI Microservice (Face Recognition + Fake Detection)
AI_SERVICE_URL=http://localhost:6000
